APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Apex URL. For local dev, lvh.me shares login across subdomains (recommended).
# Login: http://lvh.me:8000 — Journal: http://{subdomain}.lvh.me:8000
APP_URL=http://lvh.me:8000
APP_BASE_DOMAIN=lvh.me

# Maximum journals per installation (plan limit)
JOURNAL_MAX_JOURNALS=5

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nexarajournals
DB_USERNAME=nexarajournals
DB_PASSWORD=nexarajournals

# PHPUnit uses a separate database name (see phpunit.xml: nexarajournals_test). With Docker Compose,
# that database is created on first volume init. Otherwise: psql -c "CREATE DATABASE nexarajournals_test;"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Must match APP_BASE_DOMAIN (no leading dot). Auto-derived from APP_BASE_DOMAIN if unset.
SESSION_DOMAIN=lvh.me

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
